# ── Input device ────────────────────────────────────────────────────────
# Part of your microphone's name — empty = PipeWire default
# Find yours: python3 -c "import sounddevice; print(sounddevice.query_devices())"
INPUT_DEVICE=

# ── Transcription ────────────────────────────────────────────────────────
# openai = Whisper API (needs API key, ~1-2s latency)
# local  = faster-whisper offline (no API key, needs: pip install faster-whisper)
TRANSCRIPTION_BACKEND=openai

# Language for Whisper (de, en, fr, ...) — empty = auto-detect
WHISPER_LANGUAGE=de

# ── Local Whisper model (only for TRANSCRIPTION_BACKEND=local) ───────────
# tiny=fast/less accurate  base=good balance  medium=better  large-v3=best
WHISPER_MODEL=base

# ── OpenAI API ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# LLM model for cleanup and rewrite modes
LLM_MODEL=gpt-4o-mini
